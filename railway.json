{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
      "builder": "NIXPACKS",
      "buildCommand": "dotnet restore && dotnet publish -c Release -o out"
    },
    "deploy": {
      "startCommand": "dotnet out/StudyMonitor.dll",
      "restartPolicyType": "ON_FAILURE"
    }
  }