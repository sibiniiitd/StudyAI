@model StudyMonitor.Models.SessionReport
@{
    ViewData["Title"] = "Session Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="report-page">
    <div class="noise"></div>

    <!-- Report Header -->
    <div class="report-header">
        <div class="rh-left">
            <div class="logo">◈ StudyAI</div>
            <div class="report-meta">
                <span>@Model.SessionDate.ToString("dd MMM yyyy, h:mm tt")</span>
                <span>•</span>
                <span>@Model.SubjectName</span>
            </div>
        </div>
        <div class="rh-center">
            <h1 class="report-name">@Model.StudentName</h1>
            <div class="report-subtitle">Study Session Report</div>
        </div>
        <div class="rh-right">
            <div class="grade-badge grade-@Model.PerformanceGrade.ToLower().Replace("+","plus")">
                <span class="grade-val">@Model.PerformanceGrade</span>
                <span class="grade-label">Grade</span>
            </div>
        </div>
    </div>

    <!-- Top Stats Row -->
    <div class="report-stats-row">
        <div class="rs-card primary">
            <div class="rs-icon">🎯</div>
            <div class="rs-val">@Model.OverallFocusScore%</div>
            <div class="rs-label">Focus Score</div>
        </div>
        <div class="rs-card">
            <div class="rs-icon">⏱</div>
            <div class="rs-val">@Model.TotalDurationMinutes min</div>
            <div class="rs-label">Duration</div>
        </div>
        <div class="rs-card">
            <div class="rs-icon">✅</div>
            <div class="rs-val">@Model.CompletionPercentage.ToString("F0")%</div>
            <div class="rs-label">Target Completed</div>
        </div>
        <div class="rs-card">
            <div class="rs-icon">🧠</div>
            <div class="rs-val">@Model.FocusedMinutes</div>
            <div class="rs-label">Focused Snapshots</div>
        </div>
        <div class="rs-card danger">
            <div class="rs-icon">⚠</div>
            <div class="rs-val">@(Model.TabSwitchCount + Model.LookAwayCount + Model.PhoneDetectionCount)</div>
            <div class="rs-label">Total Distractions</div>
        </div>
    </div>

    <div class="report-body">
        <!-- Left Column -->
        <div class="report-col-left">

            <!-- AI Summary -->
            <div class="report-card ai-summary-card">
                <div class="card-header">
                    <span class="card-title">🤖 AI Summary</span>
                    <span class="ai-tag">Generated by AI</span>
                </div>
                <p class="ai-summary-text">@Model.AISummary</p>
            </div>

            <!-- Focus Chart -->
            <div class="report-card">
                <div class="card-header">
                    <span class="card-title">📈 Focus Timeline</span>
                </div>
                @if (Model.HourlyData.Any())
                {
                    <div class="report-chart">
                        @foreach (var d in Model.HourlyData)
                        {
                            var h = Math.Max(8, (int)(d.FocusScore / 100.0 * 120));
                            var color = d.FocusScore >= 80 ? "#00ff9d" : d.FocusScore >= 60 ? "#ffd93d" : d.FocusScore >= 40 ? "#ff9f43" : "#ff4444";
                            <div class="report-bar-wrap">
                                <div class="report-bar" style="height:@(h)px;background:@color" title="@d.FocusScore% at @d.TimeLabel"></div>
                                <div class="report-bar-label">@d.TimeLabel</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="no-data">No timeline data collected</p>
                }
                <div class="chart-legend">
                    <span class="leg excellent">Excellent (80+)</span>
                    <span class="leg good">Good (60-80)</span>
                    <span class="leg moderate">Moderate (40-60)</span>
                    <span class="leg low">Low (&lt;40)</span>
                </div>
            </div>

            <!-- Distraction Breakdown -->
            <div class="report-card">
                <div class="card-header">
                    <span class="card-title">🔍 Distraction Breakdown</span>
                </div>
                <div class="distraction-grid">
                    <div class="dis-item">
                        <div class="dis-icon">🔄</div>
                        <div class="dis-bar-wrap">
                            <span class="dis-label">Tab Switches</span>
                            <div class="dis-bar">
                                <div class="dis-fill" style="width:@(Math.Min(100, Model.TabSwitchCount * 10))%"></div>
                            </div>
                        </div>
                        <div class="dis-count @(Model.TabSwitchCount > 5 ? "danger" : "")">@Model.TabSwitchCount</div>
                    </div>
                    <div class="dis-item">
                        <div class="dis-icon">👀</div>
                        <div class="dis-bar-wrap">
                            <span class="dis-label">Look Aways</span>
                            <div class="dis-bar">
                                <div class="dis-fill warning" style="width:@(Math.Min(100, Model.LookAwayCount * 5))%"></div>
                            </div>
                        </div>
                        <div class="dis-count @(Model.LookAwayCount > 10 ? "danger" : "")">@Model.LookAwayCount</div>
                    </div>
                    <div class="dis-item">
                        <div class="dis-icon">📱</div>
                        <div class="dis-bar-wrap">
                            <span class="dis-label">Phone Usage</span>
                            <div class="dis-bar">
                                <div class="dis-fill danger" style="width:@(Math.Min(100, Model.PhoneDetectionCount * 15))%"></div>
                            </div>
                        </div>
                        <div class="dis-count @(Model.PhoneDetectionCount > 2 ? "danger" : "")">@Model.PhoneDetectionCount</div>
                    </div>
                    <div class="dis-item">
                        <div class="dis-icon">🥱</div>
                        <div class="dis-bar-wrap">
                            <span class="dis-label">Yawns (Fatigue)</span>
                            <div class="dis-bar">
                                <div class="dis-fill warning" style="width:@(Math.Min(100, Model.YawnCount * 12))%"></div>
                            </div>
                        </div>
                        <div class="dis-count">@Model.YawnCount</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="report-col-right">

            <!-- Performance Ring -->
            <div class="report-card score-card">
                <div class="card-header">
                    <span class="card-title">📊 Performance</span>
                </div>
                <div class="big-ring-wrap">
                    <svg viewBox="0 0 160 160" class="big-ring">
                        <circle cx="80" cy="80" r="65" fill="none" stroke="#1a1a2e" stroke-width="14"/>
                        <circle cx="80" cy="80" r="65" fill="none" 
                                stroke="@(Model.OverallFocusScore >= 75 ? "#00ff9d" : Model.OverallFocusScore >= 55 ? "#ffd93d" : "#ff4444")" 
                                stroke-width="14" stroke-linecap="round"
                                stroke-dasharray="408" 
                                stroke-dashoffset="@(408 - (408 * Model.OverallFocusScore / 100))"
                                transform="rotate(-90 80 80)"/>
                    </svg>
                    <div class="big-ring-text">
                        <div class="big-score">@Model.OverallFocusScore%</div>
                        <div class="big-grade">Grade @Model.PerformanceGrade</div>
                    </div>
                </div>
                <div class="period-info">
                    <div class="pi-item">
                        <span>🌟 Best Focus</span>
                        <strong>@Model.BestFocusPeriod</strong>
                    </div>
                    <div class="pi-item">
                        <span>📉 Lowest Focus</span>
                        <strong>@Model.WorstFocusPeriod</strong>
                    </div>
                </div>
            </div>

            <!-- Strengths -->
            <div class="report-card">
                <div class="card-header">
                    <span class="card-title">💪 Strengths</span>
                </div>
                <ul class="insight-list strengths">
                    @foreach (var s in Model.Strengths)
                    {
                        <li>@s</li>
                    }
                </ul>
            </div>

            <!-- Improvements -->
            <div class="report-card">
                <div class="card-header">
                    <span class="card-title">🚀 Areas to Improve</span>
                </div>
                <ul class="insight-list improvements">
                    @foreach (var i in Model.Improvements)
                    {
                        <li>@i</li>
                    }
                </ul>
            </div>

            <!-- AI Recommendations -->
            <div class="report-card ai-rec-card">
                <div class="card-header">
                    <span class="card-title">🤖 AI Recommendations</span>
                    <span class="ai-tag">Personalized</span>
                </div>
                <ul class="insight-list recs">
                    @foreach (var r in Model.AIRecommendations)
                    {
                        <li>@r</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- Footer Actions -->
    <div class="report-footer">
        <a href="/" class="action-btn secondary">← New Session</a>
        <button class="action-btn primary" onclick="window.print()">🖨 Print Report</button>
    </div>
</div>
